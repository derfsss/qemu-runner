.KEY platform
.BRA {
.KET }

; AutoInstall for SerialShell
; TCP command listener for AmigaOS 4 remote development
; Generated by AmiUpdate Integration Toolkit

; Get the install path from APPDIR
Set AUInstallPath `GetEnv AppDir/SerialShell`

; Fallback to default path if APPDIR not set
If "$AUInstallPath" EQ ""
  Set AUInstallPath "C:"
EndIf

; Install critical files via CopyStore (enables RollBack)
CopyStore SerialShell "$AUInstallPath"

; Install additional files
Copy SerialShell.readme "$AUInstallPath" CLONE QUIET

; Installation complete
echo ""
echo "SerialShell has been installed."
echo "Add to S:User-Startup:"
echo "  Run <>CON:0/0/640/200/SerialShell/AUTO/CLOSE C:SerialShell"
echo ""

UnSet AUInstallPath

